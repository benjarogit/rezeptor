# EditorConfig — baseline whitespace only (no formatter war in CI).
# See audit finding 001-no-editorconfig-or-formatter-in-ci.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{sh,bats}]
indent_style = space
indent_size = 4

[*.{py,yml,yaml,json,md}]
indent_style = space
indent_size = 4

[Makefile]
indent_style = tab
