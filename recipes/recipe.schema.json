{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/benjarogit/rezeptor/recipes/recipe.schema.json",
  "title": "Rezeptor recipe.yml",
  "type": "object",
  "required": [
    "id",
    "name",
    "icon",
    "data_root",
    "runtime",
    "install_type",
    "source_kind",
    "fix_kind",
    "install",
    "launch",
    "validate",
    "repair",
    "kill",
    "uninstall",
    "install_steps"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "name": { "type": "string", "minLength": 1 },
    "icon": {
      "type": "string",
      "minLength": 1,
      "description": "Pfad zum Rezept-Icon, z. B. {repo}/images/<id>-icon.png (PNG/SVG, empfohlen 256²)"
    },
    "category": { "type": "string" },
    "version_guaranteed": { "type": "string" },
    "version_label": { "type": "string" },
    "version_detect": {
      "type": "array",
      "description": "Deklarative Versionserkennung (Rezeptor-Kern). Pflicht wenn version_guaranteed gesetzt.",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["kind"],
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "json_key",
              "text_regex",
              "path_regex",
              "pe_field",
              "pe_contains",
              "filename_regex",
              "stack"
            ]
          }
        },
        "additionalProperties": true
      }
    },
    "author": { "type": "string" },
    "notify_title": { "type": "string" },
    "steam_appid": { "type": "string" },
    "steam_target_folder": { "type": "string" },
    "data_root": { "type": "string", "minLength": 1 },
    "prefix": { "type": "string" },
    "runtime": { "enum": ["proton-ge", "system"] },
    "install_type": {
      "enum": [
        "installer_offline",
        "portable_launch",
        "portable_bootstrap",
        "game_install",
        "game_portable",
        "adobe_offline",
        "portable"
      ]
    },
    "source_kind": {
      "enum": ["folder", "installer", "archive", "fixed_path"]
    },
    "fix_kind": { "enum": ["none", "optional", "required"] },
    "source_formats": { "type": "string" },
    "source_label": { "type": "string" },
    "installer_dir": { "type": "string" },
    "deploy_mode": { "enum": ["copy", "link", "move"] },
    "target_default": { "type": "string" },
    "target_label": { "type": "string" },
    "portable_root": { "type": "string" },
    "exe_glob": { "type": "string" },
    "winetricks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "env": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "rezeptor_min": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+"
    },
    "install": { "type": "string" },
    "launch": { "type": "string" },
    "validate": { "type": "string" },
    "repair": { "type": "string" },
    "kill": { "type": "string" },
    "uninstall": { "type": "string" },
    "install_steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          {
            "type": "string",
            "enum": [
              "prepare_source",
              "require_portable",
              "prefix",
              "winetricks",
              "deploy_graphics",
              "run_installer",
              "stabilize_prefix",
              "win10",
              "fonts_registry",
              "emit_log_paths"
            ]
          },
          {
            "type": "object",
            "minProperties": 1,
            "maxProperties": 1,
            "additionalProperties": true
          }
        ]
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "source_kind": { "const": "archive" } },
        "required": ["source_kind"]
      },
      "then": { "required": ["source_formats"] }
    },
    {
      "if": {
        "properties": { "source_kind": { "const": "fixed_path" } },
        "required": ["source_kind"]
      },
      "then": { "required": ["installer_dir"] }
    }
  ],
  "additionalProperties": true
}
