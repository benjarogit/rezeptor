#!/usr/bin/env bash
# AppImage entry: start Rezeptor GUI. BYOS installer is chosen in the GUI (no terminal prompt).
set -eu
HERE="$(dirname "$(readlink -f "$0")")"
export APPDIR="$HERE"
export PROJECT_ROOT="$HERE/usr/share/rezeptor"
# Legacy path (pre-rezeptor rename) — only if new tree missing
if [ ! -d "$PROJECT_ROOT" ] && [ -d "$HERE/usr/share/photoshopCClinux" ]; then
    export PROJECT_ROOT="$HERE/usr/share/photoshopCClinux"
fi
# venv python3 first (install_steps call python3); bundled helpers; then core.
export PATH="$HERE/venv/bin:$HERE/usr/bin:$HERE/runtime/winetricks:$PROJECT_ROOT/core:$PATH"
export REZEPTOR_APPIMAGE=1
# Prefer desktop portal when present (pip Qt in AppImage lacks KDEPlasmaPlatformTheme).
if [ -z "${QT_QPA_PLATFORMTHEME:-}" ]; then
    case "${XDG_CURRENT_DESKTOP:-}${KDE_FULL_SESSION:+KDE}" in
        *KDE*|*Plasma*) export QT_QPA_PLATFORMTHEME=xdgdesktopportal ;;
    esac
fi

APPIMAGE_PYTHON="$HERE/venv/bin/python"
if [ -x "$APPIMAGE_PYTHON" ] && "$APPIMAGE_PYTHON" -c "import PyQt6" 2>/dev/null; then
    export PYTHON="$APPIMAGE_PYTHON"
elif python3 -c "import PyQt6" 2>/dev/null; then
    export PYTHON="python3"
else
    # No TTY assumed (double-click). Bundled venv from build-appimage.sh should provide PyQt6.
    echo "PyQt6 missing: rebuild AppImage (bundled venv) or install host python-pyqt6." >&2
    exit 1
fi

# Optional: pre-seed from env (CI / advanced). Never block on terminal input.
if [ -n "${PHOTOSHOP_INSTALLER_DIR:-}" ] && [ -f "${PHOTOSHOP_INSTALLER_DIR}/Set-up.exe" ]; then
    mkdir -p "$PROJECT_ROOT/photoshop"
    ln -sfn "$PHOTOSHOP_INSTALLER_DIR/Set-up.exe" "$PROJECT_ROOT/photoshop/Set-up.exe" 2>/dev/null || true
fi

cd "$PROJECT_ROOT"
if ! "$PYTHON" -c "import PyQt6" 2>/dev/null; then
    echo "PyQt6 import failed." >&2
    exit 1
fi
exec "$PYTHON" "$PROJECT_ROOT/launcher/launcher.py" "$@"
