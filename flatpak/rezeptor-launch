#!/usr/bin/env bash
# Flatpak entry: start Rezeptor GUI. BYOS installer is chosen in the GUI (no terminal prompt).
set -eu
HERE="/app"
export APPDIR="$HERE"
export PROJECT_ROOT="$HERE/share/rezeptor"
export REZEPTOR_FLATPAK=1
export PATH="$HERE/python/bin:$HERE/bin:$HERE/runtime/winetricks:$PROJECT_ROOT/core:$PATH"

if [ -z "${QT_QPA_PLATFORMTHEME:-}" ]; then
    case "${XDG_CURRENT_DESKTOP:-}${KDE_FULL_SESSION:+KDE}" in
        *KDE*|*Plasma*) export QT_QPA_PLATFORMTHEME=xdgdesktopportal ;;
    esac
fi

FLATPAK_PYTHON="$HERE/python/bin/python3"
if [ ! -x "$FLATPAK_PYTHON" ]; then
    echo "Bundled Python missing — rebuild Flatpak (scripts/build-flatpak.sh)." >&2
    exit 1
fi
if ! "$FLATPAK_PYTHON" -c "import PyQt6"; then
    echo "Bundled PyQt6 missing or broken — rebuild Flatpak." >&2
    exit 1
fi
export PYTHON="$FLATPAK_PYTHON"

if [ -n "${PHOTOSHOP_INSTALLER_DIR:-}" ] && [ -f "${PHOTOSHOP_INSTALLER_DIR}/Set-up.exe" ]; then
    mkdir -p "$PROJECT_ROOT/photoshop"
    ln -sfn "$PHOTOSHOP_INSTALLER_DIR/Set-up.exe" "$PROJECT_ROOT/photoshop/Set-up.exe" 2>/dev/null || true
fi

cd "$PROJECT_ROOT"
STATE_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/rezeptor"
mkdir -p "$STATE_DIR"
cd "$STATE_DIR"
exec "$PYTHON" "$PROJECT_ROOT/launcher/launcher.py" "$@"
