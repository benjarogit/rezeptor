# Photoshop CC Linux - GitIgnore

# ============================================================
# Installation Files (User must provide these)
# ============================================================
photoshop/Set-up.exe
photoshop/packages/
photoshop/products/
photoshop/resources/
photoshop/replacement/
photoshop/*.exe
photoshop/*.dll
photoshop/*.msi
photoshop/*.zip
photoshop/*.pima
photoshop/*.pimx
photoshop/*.sig
photoshop/*.xml
photoshop/*.json
photoshop/*.dat
photoshop/*.idx

# Keep structure but ignore content
!photoshop/.gitkeep

# ============================================================
# Runtime/User Data
# ============================================================
~/.photoshopCCV19/
~/.cache/photoshopCCV19/
~/.psdata.txt
*.psdata.txt
logs/
*.log
config/
*.backup
*.bak
wine-error.log
setuplog.log
photoshop-runtime.log

# ============================================================
# Local Version File (updated automatically on update)
# ============================================================
VERSION

# ============================================================
# Temporary Files
# ============================================================
*.swp
*.swo
*~
*.tmp
*.temp
/tmp/.photoshop_*
_
.DS_Store
Thumbs.db
.directory
desktop.ini

# ============================================================
# Developer Tools (not for end users)
# ============================================================
gitpush.sh
stagefiles.sh
tests/
.shellcheckrc

# ============================================================
# Developer Documentation (not for end users)
# ============================================================
ATTACK_SCENARIO_REPORT.md
BLIND_SPOT_AUDIT.md
CODE_REVIEW_REPORT.md
RELEASE_NOTES_*.md
FINAL_CODE_REVIEW.md
GIT_PUSH_READY.md
CHANGELOG.md

# ============================================================
# AppImage build artifacts
# ============================================================
AppDir-build/
*.AppImage
.cache/proton-ge-build/

# ============================================================
# IDE/Editor Files
# ============================================================
.vscode/
.idea/
*.sublime-*
.cursor/

# ============================================================
# IMPORTANT: Keep redist/ versioned
# ============================================================
__pycache__/
squashfs-root/
launcher/assets/ui/
